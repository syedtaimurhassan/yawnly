rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /participants/{participantKey} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.nameKey == participantKey
        && request.resource.data.displayName is string;
      allow delete: if false;

      match /courses/{courseId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && request.resource.data.id == courseId
          && request.resource.data.active is bool;
        allow delete: if false;
      }

      match /sessions/{sessionId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && request.resource.data.id == sessionId
          && request.resource.data.participantKey == participantKey;
        allow delete: if false;

        match /yawnEvents/{eventId} {
          allow read: if isSignedIn();
          allow create, update: if isSignedIn()
            && request.resource.data.id == eventId
            && request.resource.data.sessionId == sessionId
            && request.resource.data.participantKey == participantKey;
          allow delete: if false;
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
